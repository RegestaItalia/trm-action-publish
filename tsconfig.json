{
    "compilerOptions": {
        "target": "ES6",
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "rootDir": "src",
        "outDir": "tmpDist",
        "sourceMap": true,
        "removeComments": true,
        "declaration": true,
        "skipLibCheck": true,
        "strict": false
    },
    "include": [
      "src/**/*"
    ]
}